# ============================================================
# Slack Socket Mode MCP Server — Environment Variables
# ============================================================
# Copy this file to .env and fill in your tokens.
# ~/.gateway/.env (global) is also supported with lower priority than ./.env.

# ---- Required ---------------------------------------------------------------

# Slack App Token (xapp-...) — for Socket Mode WebSocket connection
SLACK_APP_TOKEN=xapp-...

# Slack Bot Token (xoxb-...) — for Web API calls (postMessage, channels.list, etc.)
SLACK_BOT_TOKEN=xoxb-...

# ---- MCP / Gateway mode -----------------------------------------------------

# MCP now uses Web API-only mode by default (Socket Mode removed from MCP server).
# ChorusGate MCP runs as a pure Web API toolset — no Socket Mode conflict.

# ---- Trello MCP -------------------------------------------------------------

# Trello API key + token for Trello MCP integration (optional)
# TRELLO_API_KEY=
# TRELLO_TOKEN=

# ---- Gateway daemon ---------------------------------------------------------

# Directory where spawned `claude -p` runs (default: process.cwd())
# GATEWAY_CLAUDE_CWD=/path/to/your/project

# Reply timeout (ms) for new conversations (default: 180000 = 3 min)
# GATEWAY_REPLY_TIMEOUT_MS=180000

# Reply timeout (ms) for resumed conversations (default: 2× normal timeout)
# GATEWAY_REPLY_TIMEOUT_MS_LONG=360000

# Max concurrent `claude -p` processes (default: 3)
# GATEWAY_MAX_CONCURRENT=3

# Session idle eviction timeout (ms) (default: 86400000 = 24h)
# GATEWAY_SESSION_IDLE_MS=86400000

# Live progress updates: set to 0 to disable placeholder messages
# GATEWAY_PROGRESS=1

# Session scope: "channel" (one session per channel) or "thread" (one per thread)
# GATEWAY_SESSION_SCOPE=channel

# ---- Claude Code spawn ------------------------------------------------------

# Path to the claude binary (default: "claude")
# CLAUDE_BIN=claude

# Permission mode for headless claude -p (default: bypassPermissions)
# CLAUDE_PERMISSION_MODE=bypassPermissions

